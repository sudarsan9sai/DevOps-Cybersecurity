# ═══════════════════════════════════════════════════════════════════════════════
# Frontend Dev Dockerfile (Vite dev server with HMR)
# ═══════════════════════════════════════════════════════════════════════════════
FROM node:20-alpine

WORKDIR /app

# Install dependencies first (cached layer)
COPY package*.json ./
RUN npm ci

# Copy source (overridden by volume mount in dev)
COPY . .

# Expose Vite port
EXPOSE 5173

# Dev server
CMD ["npx", "vite", "--host", "0.0.0.0"]
