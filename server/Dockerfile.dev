# ═══════════════════════════════════════════════════════════════════════════════
# Backend Dev Dockerfile (hot-reload with ts-node-dev)
# ═══════════════════════════════════════════════════════════════════════════════
FROM node:20-alpine

WORKDIR /app

# Install dependencies first (cached layer)
COPY package*.json ./
RUN npm ci

# Copy source (overridden by volume mount in dev)
COPY . .

# Expose API port
EXPOSE 3001

# Dev server with hot-reload
CMD ["npx", "ts-node-dev", "--respawn", "--transpile-only", "src/main.ts"]
