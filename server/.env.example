# Environment Variables
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/investwise

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=investwise-dev-secret-key-change-in-production
JWT_REFRESH_SECRET=investwise-dev-refresh-secret-change-in-production
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Razorpay (stub)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# BSE StarMF (stub)
BSE_STARMF_USER_ID=INVESTWISE
BSE_STARMF_MEMBER_ID=12345
BSE_STARMF_PASSWORD=xxxxxxxx
BSE_STARMF_URL=https://bsestarmf.in/api

# DigiLocker (stub)
DIGILOCKER_CLIENT_ID=xxxxxxxx
DIGILOCKER_CLIENT_SECRET=xxxxxxxx

# Firebase (stub)
FIREBASE_PROJECT_ID=investwise-prod
FIREBASE_PRIVATE_KEY=xxxxxxxx

# Twilio (stub)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxx
TWILIO_PHONE=+911234567890

# SendGrid (stub)
SENDGRID_API_KEY=SG.xxxxxxxx
